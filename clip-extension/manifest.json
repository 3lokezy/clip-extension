{
  "manifest_version": 3,
  "name": "Clipping Net Campaign Profit Inspector",
  "version": "1.5.20",
  "description": "Look at how much tiktok accounts are making through clippping camapigns and creator funds.",
  "icons": {
    "16": "icons/icon-16.png",
    "32": "icons/icon-32.png",
    "48": "icons/icon-64.png",
    "128": "icons/icon-128.png"
  },
  "permissions": ["storage", "scripting"],
  "host_permissions": [
    "https://*.tiktok.com/*",
    "https://www.youtube.com/*",
    "https://youtube.com/*",
    "https://m.youtube.com/*",
    "https://www.instagram.com/*",
    "https://instagram.com/*"
  ],
  "action": {
    "default_title": "Clip profile inspect — settings",
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon-16.png",
      "32": "icons/icon-32.png"
    }
  },
  "content_scripts": [
    {
      "matches": [
        "https://www.tiktok.com/*",
        "https://tiktok.com/*",
        "https://*.tiktok.com/*",
        "https://www.youtube.com/*",
        "https://youtube.com/*",
        "https://m.youtube.com/*",
        "https://www.instagram.com/*",
        "https://instagram.com/*"
      ],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ]
}
